# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/terminalnews?sslmode=disable

# NewsAPI Configuration (Optional - get free key at https://newsapi.org/)
NEWSAPI_KEY=your_newsapi_key_here

# Guardian API (Optional)
GUARDIAN_API_KEY=your_guardian_key_here

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/terminal-news/scraper.log

# Fetch Settings
FETCH_INTERVAL_MINUTES=15
RSS_TIMEOUT_SECONDS=30
MAX_ARTICLES_PER_SOURCE=100

# Cleanup Settings
CLEAN_OLD_ARTICLES_DAYS=90
DEDUP_CACHE_SIZE=10000
