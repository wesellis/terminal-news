# Production Environment Configuration for Digital Ocean
# Copy to .env.production and fill in actual values

# Database
DB_NAME=terminalnews
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Backend API
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_64_CHARS_MIN
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXX

# News APIs
NEWSAPI_KEY=YOUR_NEWSAPI_KEY_HERE
GUARDIAN_API_KEY=YOUR_GUARDIAN_API_KEY_HERE

# Application
ENVIRONMENT=production
LOG_LEVEL=info
API_PORT=8080

# Domain (for nginx SSL)
DOMAIN=terminalnews.yourdomain.com
