# Terminal News - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# API Server
API_HOST=localhost
API_PORT=8080
API_BASE_URL=http://localhost:8080

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=terminalnews
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Authentication
JWT_SECRET=your_secret_key_here_change_in_production
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=168h

# News APIs
NEWS_API_KEY=your_newsapi_key_here
GUARDIAN_API_KEY=your_guardian_key_here
NYT_API_KEY=your_nyt_key_here

# Weather API (NOAA)
NOAA_API_KEY=optional_if_needed
DEFAULT_LOCATION=San Francisco, CA

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=Terminal News <noreply@terminalnews.com>

# Application
APP_ENV=development
LOG_LEVEL=debug
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# News Aggregation
NEWS_FETCH_INTERVAL=15m
NEWS_SOURCES_ENABLED=newsapi,guardian,rss
RSS_FEEDS=https://rss.cnn.com/rss/cnn_topstories.rss,https://feeds.bbci.co.uk/news/rss.xml

# Caching
CACHE_TTL_ARTICLES=5m
CACHE_TTL_RANKINGS=1m
CACHE_TTL_WEATHER=30m

# Feature Flags
ENABLE_CLASSIFIEDS=true
ENABLE_COMMENTS=true
ENABLE_WEBSOCKET=true
ENABLE_PREMIUM=false

# Moderation
AUTO_MODERATION_ENABLED=true
SPAM_THRESHOLD=0.8
PROFANITY_FILTER_ENABLED=true

# Analytics (Optional)
ANALYTICS_ENABLED=false
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# File Upload (for future features)
MAX_UPLOAD_SIZE=5mb
ALLOWED_FILE_TYPES=jpg,png,gif,pdf
